# ── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── PostgreSQL (Render / Railway provides this automatically) ──
DATABASE_URL=postgresql://user:password@host:5432/thesisvault

# ── JWT ─────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── File Storage ─────────────────────────────────────
# For local development, files are saved to /uploads
# For production, use AWS S3 (optional upgrade)
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=100

# ── Email (Nodemailer) ───────────────────────────────
# Use any SMTP provider: Gmail, SendGrid, Mailgun, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@thesisvault.edu

# ── Frontend URL (for CORS) ──────────────────────────
CLIENT_URL=http://localhost:3000

# ── Admin Bootstrap ─────────────────────────────────
ADMIN_EMAIL=admin@thesisvault.edu
ADMIN_PASSWORD=Admin@123456
